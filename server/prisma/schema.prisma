generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  Admin
  AssetManager
  DeptHead
  Employee
}

enum UserStatus {
  Active
  Inactive
}

enum DepartmentStatus {
  Active
  Inactive
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(Employee)
  status       UserStatus @default(Active)

  departmentId Int?
  department   Department? @relation("DepartmentUsers", fields: [departmentId], references: [id])

  // User can head at most one department
  headedDepartment Department? @relation("DepartmentHead")

  notifications Notification[]
  activityLogs  ActivityLog[]

  // Asset allocations and bookings relationships
  assets        Asset[]           @relation("UserAssets")
  allocations   Allocation[]
  transfersFrom TransferRequest[] @relation("FromUserTransfers")
  transfersTo   TransferRequest[] @relation("ToUserTransfers")
  bookings      Booking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id     Int              @id @default(autoincrement())
  name   String           @unique
  status DepartmentStatus @default(Active)

  // One department can have one head
  headId Int?  @unique
  head   User? @relation("DepartmentHead", fields: [headId], references: [id])

  // Optional parent department
  parentDepartmentId Int?
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[] @relation("DepartmentHierarchy")

  // Employees in this department
  users User[] @relation("DepartmentUsers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id           Int    @id @default(autoincrement())
  name         String @unique
  customFields Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  type    String
  message String
  isRead  Boolean @default(false)

  createdAt DateTime @default(now())
}

model ActivityLog {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  action     String
  entityType String
  entityId   Int

  timestamp DateTime @default(now())
}

model Asset {
  id                 String             @id
  name               String
  type               String             // e.g. "Laptop", "Monitor", etc.
  serialNumber       String             @unique
  specification      String
  department         String
  status             String             @default("Available") // "Available", "Allocated", "Overdue", "Maintenance"
  currentHolderId    Int?
  currentHolder      User?              @relation("UserAssets", fields: [currentHolderId], references: [id])
  allocatedDate      DateTime?
  expectedReturnDate DateTime?
  allocations        Allocation[]
  transfers          TransferRequest[]

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model Allocation {
  id                 Int       @id @default(autoincrement())
  assetId            String
  asset              Asset     @relation(fields: [assetId], references: [id])
  userId             Int
  user               User      @relation(fields: [userId], references: [id])
  allocatedDate      DateTime  @default(now())
  returnedDate       DateTime?
  expectedReturnDate DateTime?
  conditionOnReturn  String?
  notes              String?
  status             String    // "Allocated", "Returned", "Overdue"

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model TransferRequest {
  id             Int      @id @default(autoincrement())
  assetId        String
  asset          Asset    @relation(fields: [assetId], references: [id])
  fromUserId     Int
  fromUser       User     @relation("FromUserTransfers", fields: [fromUserId], references: [id])
  toUserId       Int
  toUser         User     @relation("ToUserTransfers", fields: [toUserId], references: [id])
  reason         String
  priority       String   // "Low", "Medium", "High"
  status         String   @default("Pending") // "Pending", "Approved", "Rejected"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Resource {
  id        String    @id
  name      String
  type      String    // "Room", "Vehicle", "Equipment"
  capacity  String
  location  String
  status    String    @default("Available")
  bookings  Booking[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Booking {
  id         Int      @id @default(autoincrement())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id])
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  date       DateTime // Date of the booking
  startTime  String   // e.g. "09:00"
  endTime    String   // e.g. "10:00"
  purpose    String
  status     String   // "Upcoming", "Ongoing", "Completed", "Cancelled"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

